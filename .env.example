# Pranav Dhyan Yoga Ashram Backend Environment Configuration (.env.example)
# Server Port (Configurable via environment variable; production platforms like Render/Railway automatically inject $PORT)
PORT=8081

# For local development without PostgreSQL, omit DB_URL / DB_DRIVER or leave as H2 defaults below:
DB_URL=jdbc:h2:file:./data/ashram_media_db;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=
JPA_DIALECT=org.hibernate.dialect.H2Dialect

# For Production PostgreSQL, uncomment and configure:
# DB_URL=jdbc:postgresql://localhost:5432/ashram_media
# DB_DRIVER=org.postgresql.Driver
# DB_USERNAME=postgres
# DB_PASSWORD=secret
# JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# JWT Security Secret (must be at least 256 bits / 32 characters)
JWT_SECRET=PranavDhyanAshramSacredSecretKeyForJwtAuthentication2026!
JWT_EXPIRATION=86400000

# CORS Allowed Origins (comma separated)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Demo Data & Account Seeding Flag (Set to true ONLY in local dev/testing; default false in production)
SEED_DEMO_DATA=false
